{
  "name": "@homebrew-forge/runtime-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./health": {
      "types": "./dist/runtimeHealth.d.ts",
      "import": "./dist/runtimeHealth.js"
    },
    "./server": {
      "types": "./dist/createRuntimeServer.d.ts",
      "import": "./dist/createRuntimeServer.js"
    }
  },
  "bin": {
    "homebrew-forge-runtime": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit --pretty false",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@homebrew-forge/editor-core": "workspace:*",
    "@homebrew-forge/forge": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  }
}
